{
  "antigravity-kit": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/kit-wake-word.mjs\"",
        "timeout": 10,
        "statusMessage": "kit: checking wake words"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/danger-guard.mjs\"",
            "timeout": 15,
            "statusMessage": "kit: danger guard"
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/rtk-enforcer.mjs\"",
            "timeout": 15,
            "statusMessage": "kit: rtk token hygiene"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(write_to_file|multi_replace_file_content|write_file|replace_file_content|apply_patch|Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/diagnostics-handoff.mjs\"",
            "timeout": 15,
            "statusMessage": "kit: diagnostics guidance"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/goal-continuation.mjs\"",
        "timeout": 10,
        "statusMessage": "kit: goal continuation check"
      }
    ]
  }
}
